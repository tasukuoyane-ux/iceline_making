# ===== 管理コンソール (/console) 用の環境変数 =====
# Vercel のプロジェクト設定 > Environment Variables に登録してください。
# （ローカルで `vercel dev` を使う場合は .env にコピーして設定）

# --- 認証 ---
# JWTの署名鍵。十分に長いランダム文字列を設定（例: openssl rand -hex 32）
JWT_SECRET=

# 社員アカウント一覧（JSON配列）。passwordHash は scripts/hash-password.mjs で生成。
# 例: [{"username":"tanaka","name":"田中太郎","passwordHash":"$2a$10$..."}]
CONSOLE_USERS=

# --- 公開（GitHubへコミット → Vercel自動デプロイ）---
# repo の contents への書き込み権限を持つ GitHub トークン（fine-grained 推奨）
GITHUB_TOKEN=
GITHUB_OWNER=tasukuoyane-ux
GITHUB_REPO=
# 本番ブランチ（未設定なら main）
GITHUB_BRANCH=main

# --- 画像アップロード（Vercel Blob）---
# Vercel ダッシュボードで Blob ストアを作成すると自動で注入されます。
# 手動で使う場合のみ設定してください。
BLOB_READ_WRITE_TOKEN=
